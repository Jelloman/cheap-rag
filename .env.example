# CHEAP RAG Environment Configuration
# Copy this file to .env and fill in your values

# Configuration profile to use
# Options: local, claude, hybrid
CONFIG_PROFILE=local

# Claude API Configuration (required for claude and hybrid modes)
ANTHROPIC_API_KEY=your_anthropic_api_key_here

# Optional: Override default paths
# VECTOR_DB_PATH=./data/vector_db
# METADATA_OUTPUT_PATH=./data/metadata
# LOG_PATH=./logs

# Optional: Model cache directory
# HF_HOME=./models

# Optional: GPU device selection (for multi-GPU systems)
# CUDA_VISIBLE_DEVICES=0

# Optional: Logging level
# LOG_LEVEL=INFO

# Optional: API server configuration
# API_HOST=0.0.0.0
# API_PORT=8000

# Database Configuration (for database metadata extraction)
# PostgreSQL/Odoo Database Password
ODOO_DB_PASSWORD=odoo

# Optional: Other database credentials
# POSTGRES_PASSWORD=your_postgres_password
# MYSQL_PASSWORD=your_mysql_password
